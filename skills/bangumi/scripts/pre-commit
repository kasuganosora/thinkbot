#!/bin/bash
# Git pre-commit hook: auto-fmt + lint check
set -e

echo "🔍 gofmt..."
cd "$(git rev-parse --show-toplevel)/cli"
unformatted=$(gofmt -l .)
if [ -n "$unformatted" ]; then
  echo "  📝 formatting..."
  gofmt -w .
  git add -A
fi

echo "🔍 golangci-lint..."
golangci-lint run ./... --timeout=2m 2>/dev/null || {
  echo "  ⚠️ golangci-lint 未安装或发现问题，跳过"
}

echo "✅ pre-commit OK"
