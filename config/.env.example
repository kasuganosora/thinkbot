# =============================================================================
# thinkbot 配置文件示例
# 复制为 .env 并修改值。
#
# 注意：LLM 配置不在此文件中，请通过数据库设置。
#
# 优先级（从高到低）：
#   1. 运行时覆盖（代码 SetTemporary）
#   2. .env 文件
#   3. 数据库（config_settings 表）
#   4. 操作系统环境变量
#   5. 默认值
# =============================================================================

# --- 数据库 ---
db.path=thinkbot.db

# --- 日志 ---
log.level=debug

# --- LLM 配置（通过数据库设置，不在此配置）---
# 在数据库 config_settings 表中添加：
#
# 1. 定义 LLM（键 llm.<id>，值为 JSON）：
#    llm.main  = {"provider":"openai","model":"gpt-4o","api_key":"sk-xxx","temperature":0.7,"max_tokens":4096}
#    llm.light = {"provider":"openai","model":"gpt-4o-mini","api_key":"sk-xxx","temperature":0.3}
#
# 2. 为 Bot 分配 LLM 角色：
#    bot.mybot.main  = main
#    bot.mybot.light = light

# --- 集成测试 LLM 配置 ---
# 集成测试（agent/memory, agent/bot, workflow）从 .env 读取以下配置：
TEST_LLM_API_KEY=your-api-key-here
TEST_LLM_PROVIDER=bigmodel
TEST_LLM_BASE_URL=https://open.bigmodel.cn/api/coding/paas
TEST_LLM_CHAT_PATH=/v4/chat/completions
TEST_LLM_MODEL=glm-5.2

# --- Bot 全局配置 ---
bot.system_prompt=You are a helpful assistant.
# bot.workers=4

# --- Channel 配置 ---
# 格式：channel.{name}.type, channel.{name}.token, channel.{name}.host

# Misskey
# channel.misskey-main.type=misskey
# channel.misskey-main.host=https://misskey.io
# channel.misskey-main.token=your-misskey-token

# Telegram
# channel.tg-main.type=telegram
# channel.tg-main.token=123456:ABC-DEF-your-telegram-token
